# In docker compose the hostnames are the service names: redis://redis:6379
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:pass@host/db
# ai-service internal endpoint — http://ai-service:8000 inside docker compose
AI_SERVICE_URL=http://localhost:8000
# Parallel jobs per queue (optional, default 2)
WORKER_CONCURRENCY=2
