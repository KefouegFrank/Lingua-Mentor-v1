{
  "name": "api-gateway",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.2",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@lingumentor/shared-schemas": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "bullmq": "^5.80.10",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.4",
    "pg": "^8.22.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.20.0",
    "eslint": "^9.17.0",
    "tsx": "^4.23.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "@node-rs/argon2-linux-x64-gnu": "2.0.2"
  }
}
