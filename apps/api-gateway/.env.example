PORT=3000
DATABASE_URL=postgres://user:pass@host/db   # Neon connection string
# In docker compose the hostname is the service name: redis://redis:6379
REDIS_URL=redis://localhost:6379
# Generated by scripts/generate-jwt-keys.sh. Paths are relative to this
# app's working directory both locally (apps/api-gateway) and in the
# container (/app), where infra/docker-compose.yml mounts ./keys read-only.
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem  # never commit real keys
