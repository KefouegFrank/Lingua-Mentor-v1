{
  "name": "lingumentor",
  "private": true,
  "version": "0.1.0",
  "description": "LinguaMentor monorepo",
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:api-gateway": "pnpm --filter api-gateway dev",
    "dev:ai-service": "cd apps/ai-service && .venv/bin/python -m uvicorn app.main:app --port 8000 --reload",
    "dev:worker": "cd apps/worker && .venv/bin/python -m app.main",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  }
}
